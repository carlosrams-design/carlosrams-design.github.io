---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogEntries from "@/components/entries/BlogEntry.astro";
import Cta from "@/components/global/Cta.astro";
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
// Sort posts by date in descending order (newest first)
const sortedPosts = allPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout>
  <section>
    <div class="py-24">
      <img src="./src/images/blog/ejemplo.png" alt="Logotipo HTML5">
      <p>20 años de experiencia como diseñador gráfico en entornos digitales. Empecé mi carrera haciendo trabajos para imprenta y en los últimos años me he desempeñado como diseñador UX/UI. Entre medias, he podido transitar muchos de los diversos ámbitos del diseño gráfico, como la creación de piezas publicitarias, infografías periodísticas o elementos de identidad visual corporativa.
      </p>
      <h3
        class="text-4xl text-balance font-medium font-display text-base-900 max-w-xl"
      >
        Portafolios de trabajos
      </h3>
      <div class="flex flex-wrap gap-3 mt-8">
        {
          tags.map((tag) => (
            <a
              class=" hover:text-blue-500 text-xs font-medium text-base-600"
              href={`/tags/${tag}`}
            >
              {tag}
            </a>
          ))
        }
      </div>
      <div class="grid grid-cols-1 mt-4 gap-8 gap-y-24 sm:grid-cols-2">
        {
          sortedPosts.map((post) => (
            <BlogEntries
              url={"/posts/" + post.id}
              alt={post.data.title}
              tags={post.data.tags}
              title={post.data.title}
              author={post.data.author}
              image={post.data.image.url}
              description={post.data.description}
              pubDate={post.data.pubDate.toString().slice(0, 10)}
            />
          ))
        }
      </div>
    </div>
  </section>
  <Cta />
</BaseLayout>
